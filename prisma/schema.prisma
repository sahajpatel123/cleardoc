generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String     @id @default(cuid())
  email                String     @unique
  emailVerified        DateTime?
  name                 String?
  image                String?
  createdAt            DateTime   @default(now())
  plan                 String     @default("free")
  stripeCustomerId     String?    @unique
  stripeSubscriptionId String?
  subscriptionStatus   String     @default("inactive")
  freeUsesRemaining    Int        @default(3)
  password             String?
  lastResetAt          DateTime   @default(now())
  tokenVersion         Int        @default(0)
  accounts             Account[]
  analyses             Analysis[]
  cases                Case[]
  sessions             Session[]
}

/// A user-owned grouping of related analyses (e.g. a single legal matter
/// with multiple document submissions over time). The previous design stored
/// `caseId` as a free-form string on Analysis with no referential integrity —
/// any value could be written, enabling confused-deputy bugs in any future
/// cross-case feature. Now: caseId FKs to Case.id, slug is the user-visible
/// identifier (unique per user), and every Case belongs to exactly one user.
model Case {
  id        String     @id @default(cuid())
  userId    String
  slug      String
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses  Analysis[]

  @@unique([userId, slug])
  @@index([userId, createdAt(sort: Desc)])
}

model Analysis {
  id           String     @id @default(cuid())
  userId       String
  createdAt    DateTime   @default(now())
  documentName String
  documentType String     @default("Unknown")
  result       Json
  chatMessages Json?
  parentId     String?
  caseId       String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Analysis?  @relation("AnalysisChain", fields: [parentId], references: [id], onDelete: SetNull)
  children     Analysis[] @relation("AnalysisChain")
  case         Case?      @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([caseId])
  @@index([parentId])
}

/// Stripe webhook idempotency — one row per processed event id (evt_...).
model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@index([createdAt])
}
