# ── Database (PostgreSQL — required for auth & saved analyses) ───
# Local dev: use the same URL for both variables.
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/cleardoc"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/cleardoc"
#
# Supabase production (recommended for Vercel):
# Use the Transaction Pooler (port 6543) for BOTH URLs to avoid connection timeouts
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── Auth.js (required) ─────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET must be ≥ 32 chars in production. The boot guard in
# lib/env.ts refuses to start in production if it is shorter.
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── NVIDIA NIM (required for analysis) ─────────────────────
# Trial endpoint default. The boot guard logs a privacy warning when this
# default is left in place for production — switch to a self-hosted NIM or
# an enterprise DPA before serving real users.
NVIDIA_API_KEY=""
# NVIDIA_API_BASE_URL="https://integrate.api.nvidia.com/v1"

# ── Stripe (required for Pro subscriptions) ────────────────
# In production, both keys MUST be `live_` (sk_live_/pk_live_). The boot
# guard refuses to start in production if a sk_test_ key is set.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Upstash Redis (recommended — rate limiting & distributed
#                        token-version cache) ────────────────
# Production REQUIRES this for the distributed token-version cache
# (lib/token-version-cache.ts) to coordinate across serverless instances.
# Without it, a Pro plan change can take up to 60s to propagate.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Sentry (optional — observability) ───────────────────────
# When SENTRY_DSN is set, the server and edge runtimes auto-init Sentry via
# instrumentation.ts. Capture rate defaults to 10% of traces; override with
# SENTRY_TRACES_SAMPLE_RATE.
# SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# NEXT_PUBLIC_SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"

# ── Health diagnostics (optional) ───────────────────────────
# Set HEALTH_CHECK_SECRET to gate deep diagnostic output from /api/health.
# The public endpoint always returns 200/503 with an empty body; sending
# `x-health-token: <HEALTH_CHECK_SECRET>` exposes DB / rate-limiter / env
# state. Generate with: openssl rand -hex 32
# HEALTH_CHECK_SECRET=""
