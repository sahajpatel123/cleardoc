# ── Database (PostgreSQL — required for auth & saved analyses) ───
# Use DATABASE_URL, or on Vercel Postgres the integration may provide:
DATABASE_URL="postgresql://user:password@host:5432/cleardoc?sslmode=require"
# POSTGRES_PRISMA_URL=""  # Vercel Postgres (Prisma) — auto-used if DATABASE_URL unset
# POSTGRES_URL=""         # Vercel Postgres direct — fallback

# ── Auth.js (required) ─────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Anthropic (required for analysis) ──────────────────────
ANTHROPIC_API_KEY=""

# ── Stripe (required for Pro subscriptions) ────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Upstash Redis (recommended — rate limiting) ────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
