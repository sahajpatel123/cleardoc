# ── Database (PostgreSQL — required for auth & saved analyses) ───
# Local dev: use the same URL for both variables.
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/cleardoc"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/cleardoc"
#
# Supabase production (recommended for Vercel):
# Use the Transaction Pooler (port 6543) for BOTH URLs to avoid connection timeouts
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── Auth.js (required) ─────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Anthropic (required for analysis) ──────────────────────
ANTHROPIC_API_KEY=""

# ── Stripe (required for Pro subscriptions) ────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Upstash Redis (recommended — rate limiting) ────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
