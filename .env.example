# ── Database (PostgreSQL — Neon, Supabase, Render, etc.) ───
DATABASE_URL="postgresql://user:password@host:5432/cleardoc?sslmode=require"

# ── Auth.js (required) ─────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Anthropic (required for analysis) ──────────────────────
ANTHROPIC_API_KEY=""

# ── Stripe (required for Pro subscriptions) ────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Upstash Redis (recommended — rate limiting) ────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
